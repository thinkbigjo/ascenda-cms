{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Offerings Categories"
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": { "i18n": { "localized": true } },
  "attributes": {
    "name": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "string",
      "required": true
    },
    "color": {
      "pluginOptions": { "i18n": { "localized": false } },
      "type": "enumeration",
      "enum": ["light-blue", "light-green", "light-purple", "light-red"],
      "required": true
    },
    "offerings": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::offering.offering",
      "mappedBy": "category"
    },
  }
}
